<style>
/* ============================================================
   V4 "COORDINATION CINEMA"
   Deep green-black stage, ambient lime light, glass layers.
   Motion system: one shared easing, one rAF loop driving
   parallax, sticky-stack, magnetic CTAs and the scroll chainage.
   Shape system: buttons 10px, cards/panels 18px, chips pill.
   ============================================================ */
:root{
  --lime:#bfd730; --lime-bright:#cbe23f; --lime-ink:#1c2405;
  --bg:#090c07; --ink-1:#0f130b; --ink-2:#151a0f;
  --glass:rgba(237,242,224,.04);
  --glass-brd:rgba(237,242,224,.10);
  --line:#262e1b;
  --text:#eef3e1; --muted:#aeba9d; --faint:#8a9679;
  --mono:'IBM Plex Mono',ui-monospace,monospace;
  --sans:'IBM Plex Sans',system-ui,sans-serif;
  --disp:'Barlow Semi Condensed',var(--sans);
  --ease:cubic-bezier(.16,1,.3,1);
  --maxw:1200px;
  --nav-h:64px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;background:var(--bg);color:var(--text);
  font-family:var(--sans);font-size:16px;line-height:1.65;
  -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
  overflow-x:hidden;
}
a{color:inherit;text-decoration:none;cursor:pointer}
button{cursor:pointer}
h1,h2,h3{text-wrap:balance}
p{text-wrap:pretty}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 clamp(20px,4vw,44px)}
:focus-visible{outline:2px solid var(--lime);outline-offset:3px;border-radius:4px}
::selection{background:var(--lime);color:var(--lime-ink)}

/* ---------- reveal (enhance-only: visible without JS) ---------- */
.js .rv{opacity:0;transform:translateY(22px);filter:blur(6px);
  transition:opacity .8s var(--ease),transform .8s var(--ease),filter .8s var(--ease);
  transition-delay:calc(var(--d,0)*90ms)}
.js .rv.in{opacity:1;transform:none;filter:none}
@media print{.js .rv{opacity:1;transform:none;filter:none}}

/* ---------- top bar: glass + chainage scroll ruler ---------- */
.topbar{position:fixed;top:0;left:0;right:0;z-index:80;
  background:rgba(9,12,7,.66);backdrop-filter:blur(18px) saturate(140%);
  -webkit-backdrop-filter:blur(18px) saturate(140%);
  border-bottom:1px solid var(--glass-brd)}
.topbar .bar{display:flex;align-items:center;gap:18px;height:var(--nav-h);padding:0 clamp(16px,2.5vw,28px)}
.brand{display:flex;align-items:center;gap:10px;flex:none}
.hdr-logo{width:30px;height:30px;border-radius:8px;display:block;flex:none}
.appname{font-family:var(--disp);font-weight:700;font-size:15.5px;letter-spacing:.05em;color:var(--text);line-height:1.15}
.appname span{display:block;font-family:var(--sans);font-weight:400;font-size:11px;letter-spacing:.03em;color:var(--faint)}
.spacer{flex:1}
.navlink{font-size:13.5px;color:var(--muted);padding:10px 6px;transition:color .2s var(--ease)}
.navlink:hover{color:var(--text)}
.tb-actions{display:flex;align-items:center;gap:12px}
.langsw{display:inline-flex;border:1px solid var(--glass-brd);border-radius:10px;overflow:hidden;background:var(--glass)}
.langsw button{border:none;border-radius:0;background:none;color:var(--faint);font-family:var(--mono);
  font-size:11.5px;letter-spacing:.06em;padding:8px 10px;min-width:36px;
  transition:background .2s var(--ease),color .2s var(--ease)}
.langsw button+button{border-left:1px solid var(--glass-brd)}
.langsw button:hover{color:var(--text)}
.langsw button.on{background:var(--lime);color:var(--lime-ink);font-weight:600}
/* scroll ruler: the page measured in chainage */
.ruler{position:relative;height:3px;background:rgba(237,242,224,.07)}
.ruler .fill{position:absolute;left:0;top:0;bottom:0;width:0;background:var(--lime);
  border-radius:0 2px 2px 0}
.ruler .chip{position:absolute;top:-24px;transform:translateX(-50%);left:0;
  font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--lime-ink);
  background:var(--lime);border-radius:999px;padding:2px 8px;opacity:0;
  transition:opacity .3s var(--ease);pointer-events:none}
.js.scrolled .ruler .chip{opacity:1}

/* ---------- buttons ---------- */
.btn{display:inline-flex;align-items:center;gap:9px;font-family:var(--disp);font-weight:700;font-size:15px;
  letter-spacing:.02em;color:var(--text);background:var(--glass);
  border:1px solid var(--glass-brd);border-radius:10px;padding:12px 22px;
  transition:transform .18s var(--ease),border-color .2s var(--ease),background .2s var(--ease),box-shadow .3s var(--ease);
  will-change:transform}
.btn:active{transform:scale(.96)}
.btn.primary{background:var(--lime);border-color:var(--lime);color:var(--lime-ink)}
.btn.lg{font-size:17px;padding:16px 30px;border-radius:12px}
.btn .ar{width:16px;height:16px;transition:transform .25s var(--ease)}
@media (hover:hover) and (pointer:fine){
  .btn:hover{border-color:var(--lime)}
  .btn.primary:hover{background:var(--lime-bright);border-color:var(--lime-bright);
    box-shadow:0 8px 40px rgba(191,215,48,.25)}
  .btn:hover .ar{transform:translateX(3px)}
}
.ghostlink{font-size:14.5px;color:var(--muted);display:inline-flex;align-items:center;gap:8px;
  border-bottom:1px solid var(--line);padding-bottom:2px;
  transition:color .2s var(--ease),border-color .2s var(--ease)}
.ghostlink:hover{color:var(--text);border-color:var(--lime)}

/* ---------- ambient light (the cinema) ---------- */
.stage{position:relative;overflow:clip}
.blob{position:absolute;border-radius:50%;pointer-events:none;filter:blur(70px);opacity:.5;
  will-change:transform}
.blob-a{width:560px;height:560px;top:-160px;right:-120px;
  background:radial-gradient(circle,rgba(191,215,48,.20),transparent 65%)}
.blob-b{width:480px;height:480px;bottom:-180px;left:-140px;
  background:radial-gradient(circle,rgba(120,150,40,.16),transparent 65%)}
.js .blob-a{animation:drift-a 22s ease-in-out infinite alternate}
.js .blob-b{animation:drift-b 28s ease-in-out infinite alternate}
@keyframes drift-a{to{transform:translate(-90px,70px) scale(1.12)}}
@keyframes drift-b{to{transform:translate(80px,-60px) scale(1.08)}}

/* ---------- hero ---------- */
.hero{position:relative;min-height:100svh;display:flex;align-items:center;
  padding-top:var(--nav-h);border-bottom:1px solid var(--line)}
.hero .wrap{display:grid;grid-template-columns:1.06fr .94fr;gap:clamp(36px,5vw,72px);
  align-items:center;width:100%;padding-top:clamp(28px,5vh,64px);padding-bottom:clamp(40px,7vh,80px)}
.hero .wrap>*{min-width:0}
.h1{font-family:var(--disp);font-weight:800;font-size:clamp(40px,4.2vw,58px);line-height:1.02;
  letter-spacing:-.015em;margin:0;color:var(--text)}
.h1 .row{display:block;overflow:hidden;padding-bottom:.06em;margin-bottom:-.06em}
.h1 .row>span{display:block}
.js .h1 .row>span{transform:translateY(115%);
  transition:transform .9s var(--ease);transition-delay:calc(var(--w,0)*120ms)}
.js .h1.in .row>span{transform:none}
.h1 .dim{color:var(--faint)}
.h1 .lime{color:var(--lime)}
.lead{margin:26px 0 0;font-size:clamp(16.5px,1.4vw,18.5px);line-height:1.7;color:var(--muted);max-width:52ch}
.hero-cta{margin-top:36px;display:flex;flex-wrap:wrap;gap:18px;align-items:center}

/* hero right: floating glass layers with pointer parallax */
.deck{position:relative;height:clamp(380px,44vw,520px)}
.layer{position:absolute;border:1px solid var(--glass-brd);border-radius:18px;
  background:linear-gradient(160deg,rgba(237,242,224,.06),rgba(237,242,224,.02));
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  box-shadow:0 30px 80px rgba(0,0,0,.5);
  padding:18px;will-change:transform}
.layer h4{margin:0 0 10px;font-family:var(--mono);font-weight:500;font-size:10.5px;
  letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
.layer svg{display:block;width:100%;height:auto}
.layer .stx{stroke:var(--faint);stroke-width:1.3;fill:none}
.layer .sta{stroke:var(--lime);fill:none}
.layer text{font-family:var(--mono);font-size:10px;fill:var(--faint);letter-spacing:.03em}
.layer-model{width:min(64%,360px);top:4%;left:0;z-index:3}
.layer-bcf{width:min(52%,300px);top:40%;right:0;z-index:4}
.layer-prof{width:min(56%,320px);bottom:2%;left:8%;z-index:2}
.float{animation:none}
.js .float-i{animation:float 7s ease-in-out infinite alternate}
@keyframes float{to{translate:0 -10px}}
.pin{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11.5px;
  white-space:nowrap;color:var(--text);background:rgba(9,12,7,.6);border:1px solid var(--glass-brd);
  border-radius:999px;padding:6px 12px;margin:4px 0}
.pin svg{width:12px;height:12px;flex:none}

/* ---------- marquee: chainage ruler of formats ---------- */
.band{border-bottom:1px solid var(--line);overflow:hidden;padding:18px 0;position:relative;background:var(--ink-1)}
.band::before,.band::after{content:"";position:absolute;top:0;bottom:0;width:110px;z-index:1;pointer-events:none}
.band::before{left:0;background:linear-gradient(90deg,var(--ink-1),transparent)}
.band::after{right:0;background:linear-gradient(270deg,var(--ink-1),transparent)}
.band-track{display:flex;width:max-content}
.js .band-track{animation:slide 40s linear infinite}
.band:hover .band-track{animation-play-state:paused}
@keyframes slide{to{transform:translateX(-50%)}}
.band-item{display:inline-flex;align-items:center;gap:28px;padding-right:28px;
  font-family:var(--mono);font-size:13px;letter-spacing:.1em;color:var(--muted);white-space:nowrap}
.band-item::after{content:"";width:1px;height:15px;background:var(--line);
  box-shadow:0 -5px 0 0 var(--lime)}

/* ---------- sections ---------- */
section{padding:clamp(76px,10vw,128px) 0}
.sec-head{max-width:64ch;margin-bottom:clamp(34px,5vw,52px)}
.sec-head h2{font-family:var(--disp);font-weight:700;font-size:clamp(30px,3.6vw,46px);
  line-height:1.05;margin:0;letter-spacing:-.01em;color:var(--text)}
.sec-head p{margin:16px 0 0;color:var(--muted);font-size:16.5px;max-width:58ch}

/* ---------- suite: sticky stack (the fluid centerpiece) ---------- */
#capabilities{padding-bottom:clamp(40px,6vw,80px)}
.stack{display:flex;flex-direction:column;gap:clamp(28px,4vw,48px)}
.panel{position:sticky;top:calc(var(--nav-h) + 28px);
  border:1px solid var(--line);border-radius:18px;background:var(--ink-1);
  padding:clamp(24px,3.5vw,48px);min-height:min(430px,62vh);
  display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(24px,4vw,56px);align-items:center;
  box-shadow:0 -18px 50px rgba(0,0,0,.35);
  transform-origin:center top;will-change:transform,opacity}
.panel:nth-child(even){grid-template-columns:.95fr 1.05fr}
.panel:nth-child(even) .panel-txt{order:2}
.panel h3{font-family:var(--disp);font-weight:700;font-size:clamp(24px,2.6vw,34px);
  margin:0 0 12px;letter-spacing:-.005em;color:var(--text)}
.panel p{margin:0;font-size:16px;color:var(--muted);line-height:1.65;max-width:48ch}
.panel-art{border:1px solid var(--line);border-radius:12px;background:var(--bg);
  padding:clamp(14px,2vw,26px);overflow:hidden}
.panel-art.gridbg{background:
  linear-gradient(var(--ink-2) 1px,transparent 1px),
  linear-gradient(90deg,var(--ink-2) 1px,transparent 1px),
  var(--bg);
  background-size:32px 32px,32px 32px,auto}
.panel-art svg{display:block;width:100%;height:auto}
.panel-art .stx{stroke:var(--faint);stroke-width:1.4;fill:none}
.panel-art .sta{stroke:var(--lime);fill:none}
.panel-art text{font-family:var(--mono);font-size:10.5px;fill:var(--faint);letter-spacing:.03em}
.pset{border:1px solid var(--line);border-radius:10px;overflow:hidden;font-family:var(--mono);font-size:12.5px}
.pset-row{display:flex;justify-content:space-between;gap:24px;padding:12px 16px;color:var(--muted)}
.pset-row+.pset-row{border-top:1px solid var(--line)}
.pset-row.hot{background:var(--lime);color:var(--lime-ink);font-weight:500}

/* ---------- privacy: the lime block, with a live data-flow ---------- */
.drench{background:var(--lime);color:var(--lime-ink);position:relative;overflow:clip}
.drench h2{font-family:var(--disp);font-weight:800;font-size:clamp(34px,4.6vw,60px);
  line-height:1.0;letter-spacing:-.015em;margin:0;max-width:16ch;color:var(--lime-ink)}
.drench .sec-p{margin:22px 0 0;font-size:17px;line-height:1.65;color:#46521c;max-width:56ch}
.flowbox{margin-top:clamp(36px,5vw,52px)}
.flowbox svg{display:block;width:100%;height:auto;max-width:860px}
.flowbox .wire{stroke:#5a691f;stroke-width:1.6;fill:none}
.flowbox .wire.cut{stroke-dasharray:6 6}
.flowbox .nodebox{fill:#0e120a}
.flowbox .nodebox.ghost{fill:none;stroke:#5a691f;stroke-width:1.6;stroke-dasharray:7 6}
.flowbox text{font-family:var(--disp);font-weight:600;font-size:15px;fill:#eef3e1;letter-spacing:.02em}
.flowbox text.sub{font-family:var(--mono);font-weight:400;font-size:10px;fill:#8a9679;letter-spacing:.04em}
.flowbox text.ghosted{fill:#3d4716;text-decoration:line-through}
.flowbox text.sub.ghosted{fill:#5a691f;text-decoration:none}
.flowbox .pulse{fill:var(--lime);stroke:#0e120a;stroke-width:2}
.js .flowbox .pulse{animation:pulse-run 3.2s var(--ease) infinite}
@keyframes pulse-run{
  0%{transform:translateX(0);opacity:0}
  12%{opacity:1}
  46%{transform:translateX(258px);opacity:1}
  58%{transform:translateX(258px);opacity:1}
  70%{transform:translateX(196px);opacity:.9}   /* bounces back off the cut link */
  100%{transform:translateX(196px);opacity:0}
}
.flowbox .deny{opacity:0;fill:none;stroke:#8f2f23;stroke-width:2.4;stroke-linecap:round}
.js .flowbox .deny{animation:deny-x 3.2s var(--ease) infinite}
@keyframes deny-x{0%,42%{opacity:0}52%,72%{opacity:1}86%,100%{opacity:0}}
.drench .foot-line{margin:30px 0 0;font-size:15.5px;color:var(--lime-ink);font-weight:600}

/* ---------- tools: fluid snap row ---------- */
.tools-row{display:flex;gap:18px;overflow-x:auto;scroll-snap-type:x proximity;
  padding:4px 4px 18px;scrollbar-width:thin;scrollbar-color:var(--line) transparent}
.tool{flex:0 0 min(300px,82vw);scroll-snap-align:start;
  border:1px solid var(--line);border-radius:18px;background:var(--ink-1);
  padding:26px 24px;display:flex;flex-direction:column;gap:12px;
  transition:transform .3s var(--ease),border-color .3s var(--ease),box-shadow .3s var(--ease);
  will-change:transform}
@media (hover:hover) and (pointer:fine){
  a.tool:hover{transform:translateY(-5px);border-color:var(--lime);
    box-shadow:0 18px 50px rgba(0,0,0,.4)}
  a.tool:hover .tool-go svg{transform:translateX(3px)}
}
.tool-io{font-family:var(--mono);font-size:11px;letter-spacing:.08em;color:var(--lime);
  border:1px solid var(--line);border-radius:999px;padding:5px 12px;align-self:flex-start}
.tool h3{font-family:var(--disp);font-weight:600;font-size:19.5px;margin:6px 0 0;letter-spacing:.01em;color:var(--text)}
.tool p{margin:0;font-size:14.5px;color:var(--muted);line-height:1.6;flex:1}
.tool-go{font-family:var(--mono);font-size:12.5px;letter-spacing:.04em;color:var(--lime);
  display:inline-flex;align-items:center;gap:7px;margin-top:6px}
.tool-go svg{width:14px;height:14px;transition:transform .25s var(--ease)}
.tool.soon{border-style:dashed;background:transparent}
.tool.soon h3{color:var(--muted)}
.tool.soon .tool-io{color:var(--faint);border-style:dashed}

/* ---------- faq ---------- */
.faq-list{max-width:860px;display:flex;flex-direction:column}
.faq-item{border-bottom:1px solid var(--line)}
.faq-item:first-child{border-top:1px solid var(--line)}
.faq-item summary{list-style:none;cursor:pointer;padding:21px 4px;font-family:var(--disp);
  font-weight:600;font-size:17.5px;letter-spacing:.01em;color:var(--text);
  display:flex;justify-content:space-between;align-items:center;gap:18px;
  transition:color .2s var(--ease)}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:"+";font-family:var(--sans);font-size:24px;font-weight:300;
  line-height:1;color:var(--lime);flex:none;transition:transform .3s var(--ease)}
.faq-item[open] summary::after{transform:rotate(45deg)}
.faq-item summary:hover{color:var(--lime)}
.faq-a{padding:0 4px 22px;color:var(--muted);font-size:15px;line-height:1.65;max-width:65ch}
.js .faq-item[open] .faq-a{animation:faq-in .35s var(--ease)}
@keyframes faq-in{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}

/* ---------- final CTA ---------- */
.cta-stage{position:relative;overflow:clip;border-top:1px solid var(--line);text-align:center}
.cta-stage h2{font-family:var(--disp);font-weight:800;font-size:clamp(38px,5.6vw,76px);
  margin:0;line-height:1.0;letter-spacing:-.015em}
.cta-stage h2 .lime{color:var(--lime)}
.cta-stage p{color:var(--muted);font-size:17px;margin:20px auto 0;max-width:46ch}
.cta-stage .hero-cta{justify-content:center;margin-top:38px}
.cta-mail{margin-top:26px;font-size:13.5px;color:var(--faint)}
.cta-mail a{color:var(--muted);border-bottom:1px solid var(--line)}
.cta-mail a:hover{color:var(--text);border-color:var(--lime)}

/* ---------- footer ---------- */
footer{border-top:1px solid var(--line);padding:44px 0 40px;background:var(--bg)}
footer .wrap{display:flex;flex-wrap:wrap;gap:22px;align-items:center}
footer .appname{font-size:14px}
footer .hdr-logo{width:26px;height:26px}
.foot-links{display:flex;gap:22px;flex-wrap:wrap}
.foot-links a{font-size:13.5px;color:var(--muted);transition:color .2s var(--ease)}
.foot-links a:hover{color:var(--text)}
.foot-meta{font-family:var(--mono);font-size:12px;color:var(--faint);width:100%;
  padding-top:22px;margin-top:6px;border-top:1px solid var(--line);
  display:flex;flex-wrap:wrap;gap:8px 20px;align-items:center}
.foot-meta a{color:var(--faint);border-bottom:1px solid var(--line)}
.foot-meta a:hover{color:var(--muted)}
.foot-disclaimer{font-family:var(--mono);font-size:11px;line-height:1.55;color:var(--faint);
  width:100%;margin:14px 0 0;max-width:82ch}

/* ---------- responsive ---------- */
@media (max-width:980px){
  .hero{min-height:0}
  .hero .wrap{grid-template-columns:1fr;gap:40px}
  .deck{height:420px;max-width:520px}
  .panel,.panel:nth-child(even){grid-template-columns:1fr;min-height:0}
  .panel:nth-child(even) .panel-txt{order:0}
  .nav-hide{display:none}
}
@media (max-width:560px){
  .hero-cta{flex-direction:column;align-items:stretch}
  .btn.lg{justify-content:center}
  .deck{height:380px}
  .layer-model{width:78%}
  .layer-bcf{width:64%}
  .layer-prof{width:70%}
  .topbar .appname span{display:none}
  .topbar .bar{gap:10px}
  .tb-actions .btn{padding:10px 14px;font-size:13.5px}
  .langsw button{padding:7px 8px}
  .foot-meta{flex-direction:column;align-items:flex-start}
  .ruler .chip{display:none}
}

/* ---------- reduced motion: everything settles, nothing autoplays ---------- */
@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .js .rv{opacity:1;transform:none;filter:none;transition:none}
  .js .h1 .row>span{transform:none;transition:none}
  .js .blob-a,.js .blob-b,.js .float-i{animation:none}
  .js .band-track{animation:none;flex-wrap:wrap;width:auto;justify-content:center;row-gap:12px;padding:0 32px}
  .js .flowbox .pulse{animation:none;opacity:0}
  .js .flowbox .deny{animation:none;opacity:1}
  .js .faq-item[open] .faq-a{animation:none}
  .btn,.tool,.faq-item summary::after{transition:none}
}
</style>
</head>

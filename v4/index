function applyLang(lang){
  const dict = I18N[lang] || I18N.it;
  document.documentElement.lang = lang;
  document.querySelectorAll("[data-i18n]").forEach(el=>{
    const k = el.getAttribute("data-i18n");
    if(dict[k] != null) el.textContent = dict[k];
  });
  document.querySelectorAll("[data-i18n-svg]").forEach(el=>{
    const k = el.getAttribute("data-i18n-svg");
    if(dict[k] != null) el.textContent = dict[k];
  });
  document.querySelectorAll(".langsw button").forEach(b=>{
    b.classList.toggle("on", b.dataset.lang === lang);
  });
  try{ localStorage.setItem("viewer_landing_lang", lang); }catch(e){}
}

(function initLang(){
  let lang = "it";
  try{ lang = localStorage.getItem("viewer_landing_lang") || (navigator.language||"it").slice(0,2); }catch(e){}
  if(!I18N[lang]) lang = "it";
  document.querySelectorAll(".langsw button").forEach(b=>{
    b.addEventListener("click", ()=>applyLang(b.dataset.lang));
  });
  applyLang(lang);
})();

/* year */
document.getElementById("year").textContent = new Date().getFullYear();

const REDUCE = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

/* hero title: masked line rise, right after first paint */
requestAnimationFrame(()=>requestAnimationFrame(()=>{
  document.getElementById("heroTitle").classList.add("in");
}));

/* marquee: duplicate track once for a seamless loop */
(function marquee(){
  const track = document.getElementById("bandTrack");
  if(!track || REDUCE) return;
  track.innerHTML += track.innerHTML;
})();

/* scroll reveal */
const io = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target); } });
},{threshold:0.12, rootMargin:"0px 0px -40px 0px"});
document.querySelectorAll(".rv").forEach(el=>io.observe(el));

/* ================================================================
   MOTION ENGINE: one rAF loop, transform/opacity only.
   Drives: chainage scroll ruler, pointer parallax on hero layers,
   sticky-stack settle, magnetic CTAs. Lerp gives the spring feel.
   ================================================================ */
(function engine(){
  const fill = document.getElementById("rulerFill");
  const chip = document.getElementById("rulerChip");
  const deck = document.getElementById("deck");
  const layers = deck ? [...deck.querySelectorAll(".layer")] : [];
  const panels = [...document.querySelectorAll("#stack .panel")];
  const magnets = [...document.querySelectorAll(".magnetic")];
  const navH = 64;

  /* pointer state for parallax + magnetic buttons */
  let px = 0, py = 0, tx = 0, ty = 0;
  if(deck && !REDUCE){
    deck.addEventListener("pointermove", (e)=>{
      const r = deck.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width - .5) * 2;   /* -1 .. 1 */
      ty = ((e.clientY - r.top) / r.height - .5) * 2;
    });
    deck.addEventListener("pointerleave", ()=>{ tx = 0; ty = 0; });
  }

  const mags = magnets.map(el=>({el, mx:0, my:0, gx:0, gy:0}));
  if(!REDUCE){
    mags.forEach(m=>{
      m.el.addEventListener("pointermove", (e)=>{
        const r = m.el.getBoundingClientRect();
        m.gx = (e.clientX - r.left - r.width/2) * .18;
        m.gy = (e.clientY - r.top - r.height/2) * .3;
      });
      m.el.addEventListener("pointerleave", ()=>{ m.gx = 0; m.gy = 0; });
    });
  }

  let scrolledFlag = false;

  function frame(){
    const doc = document.documentElement;
    const max = doc.scrollHeight - window.innerHeight;
    const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;

    /* chainage ruler */
    if(fill){
      fill.style.width = (p*100).toFixed(2) + "%";
      const m = Math.round(p*1000);
      chip.textContent = (m < 1000 ? "0+" + String(m).padStart(3,"0") : "1+000");
      chip.style.left = (p*100).toFixed(2) + "%";
    }
    const sc = window.scrollY > 40;
    if(sc !== scrolledFlag){ scrolledFlag = sc; document.documentElement.classList.toggle("scrolled", sc); }

    if(!REDUCE){
      /* hero layer parallax (lerp toward pointer) */
      px += (tx - px) * .07;
      py += (ty - py) * .07;
      layers.forEach(l=>{
        const f = parseFloat(l.dataset.px || 14);
        l.style.transform = "translate(" + (px*f).toFixed(2) + "px," + (py*f*.7).toFixed(2) + "px)";
      });

      /* sticky-stack: previous panels settle back and dim as the next arrives */
      panels.forEach((panel, i)=>{
        if(i === panels.length-1) { panel.style.transform=""; return; }
        const next = panels[i+1];
        const r = next.getBoundingClientRect();
        const start = window.innerHeight, end = navH + 28;
        const prog = Math.min(1, Math.max(0, (start - r.top) / (start - end)));
        panel.style.transform = "scale(" + (1 - prog*.05).toFixed(4) + ") translateY(" + (-prog*10).toFixed(1) + "px)";
        panel.style.opacity = (1 - prog*.35).toFixed(3);
      });

      /* magnetic CTAs */
      mags.forEach(m=>{
        m.mx += (m.gx - m.mx) * .16;
        m.my += (m.gy - m.my) * .16;
        if(Math.abs(m.mx) > .1 || Math.abs(m.my) > .1){
          m.el.style.translate = m.mx.toFixed(1) + "px " + m.my.toFixed(1) + "px";
        } else if(m.el.style.translate){ m.el.style.translate = ""; }
      });
    }

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
